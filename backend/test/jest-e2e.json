{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/test/tsconfig.json" }]
  },
  "moduleNameMapper": {
    "^@app/shared(.*)$": "<rootDir>/../shared/src$1"
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/main.ts",
    "!src/**/*.module.ts"
  ],
  "coverageDirectory": "./coverage-e2e"
}
